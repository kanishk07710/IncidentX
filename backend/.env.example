# Copy relevant values into Render's dashboard env vars (Render doesn't read .env files directly).

# --- Database (Render: Connect tab on your Postgres instance) ---
DATABASE_URL=jdbc:postgresql://<host>/<database>
DATABASE_USERNAME=<user>
DATABASE_PASSWORD=<password>

# --- Sandbox ---
# "docker" for local docker-compose dev, "node" on Render (no Docker daemon available there)
SANDBOX_MODE=node

# --- Frontend / CORS ---
FRONTEND_URL=https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# --- Cross-site cookies (required since frontend and backend are on different domains) ---
SESSION_COOKIE_SAME_SITE=None
SESSION_COOKIE_SECURE=true

# --- Optional: AI mentor feedback (OpenAI-compatible). Leave blank to use built-in mock feedback ---
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# --- Optional: OAuth login. Leave blank to use the mock-login / Practice Mode flow ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
